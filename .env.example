# Host port exposed by the Compose web service.
DOCUMENT_ARENA_WEB_PORT=3000

# Optional exact browser origins allowed to call the local runner. When unset,
# http://localhost:${DOCUMENT_ARENA_WEB_PORT} and http://127.0.0.1:${DOCUMENT_ARENA_WEB_PORT}
# are allowed. Use a comma-separated list when the web app has a custom origin.
# DOCUMENT_ARENA_RUNNER_ALLOWED_ORIGINS=http://document-arena.test:3000,https://document-arena.test

# Azure Document Intelligence (remote OCR parser). Set in a local .env; the
# runner injects these into the azure-di container. Never commit real values.
AZURE_DI_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_DI_KEY=<your-key>

# Planned hosted execution exchange. These settings belong only to the trusted
# server-side BlobStore adapter; they are not consumed by the current local
# prototype. Never expose any credential through NEXT_PUBLIC_* or browser code.
# Provision the private R2 bucket separately with a one-day object-expiration
# lifecycle rule. Runtime cleanup still explicitly deletes terminal-job objects.
# The hosted route is not implemented or enabled yet. Before deploying it, run
# `bun infra/r2/configure.mjs --verify` as a fail-closed deployment gate.
# DOCUMENT_ARENA_BLOBSTORE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# DOCUMENT_ARENA_BLOBSTORE_REGION=auto
# DOCUMENT_ARENA_BLOBSTORE_BUCKET=document-arena-execution
# DOCUMENT_ARENA_BLOBSTORE_ACCESS_KEY_ID=<server-only-access-key-id>
# DOCUMENT_ARENA_BLOBSTORE_SECRET_ACCESS_KEY=<server-only-secret-access-key>

# Provisioning/verification only; do not inject these into the web runtime.
# CLOUDFLARE_ACCOUNT_ID=<32-character-account-id>
# CLOUDFLARE_API_TOKEN=<workers-r2-storage-write-token>
# DOCUMENT_ARENA_R2_ALLOWED_ORIGINS=https://document-arena.example
# DOCUMENT_ARENA_R2_JURISDICTION=default

# Planned hosted compute placement. GCP receives short-lived presigned object
# URLs for a job; it does not receive the R2 account credentials above.
# Hosted execution is fail-closed and this flag must remain false until auth,
# quota/grants, R2 policy verification, and GCP Workload Identity Federation all
# pass in the target environment.
# DOCUMENT_ARENA_HOSTED_EXECUTION_ENABLED=false
# DOCUMENT_ARENA_GCP_PROJECT=<gcp-project-id>
# DOCUMENT_ARENA_GCP_REGION=asia-northeast3
# DOCUMENT_ARENA_GCP_BATCH_SERVICE_ACCOUNT=<batch-service-account-email>

# Planned hosted operational database and authentication. Local workspaces do
# not require these. Better Auth uses a separate `auth` schema in the same Neon
# PostgreSQL database; start with GitHub OAuth only so no email service is needed.
# DATABASE_URL=<server-only-neon-pooled-connection-string>
# BETTER_AUTH_URL=https://document-arena.example
# BETTER_AUTH_SECRET=<server-only-high-entropy-secret>
# GITHUB_CLIENT_ID=<oauth-app-client-id>
# GITHUB_CLIENT_SECRET=<server-only-oauth-app-secret>
