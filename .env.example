# Host port exposed by the Compose web service.
PARSER_ARENA_WEB_PORT=3000

# Azure Document Intelligence (remote OCR parser). Set in a local .env; the
# runner injects these into the azure-di container. Never commit real values.
AZURE_DI_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_DI_KEY=<your-key>
