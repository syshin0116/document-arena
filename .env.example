# Host port exposed by the Compose web service.
DOCUMENT_ARENA_WEB_PORT=3000

# Optional exact browser origins allowed to call the local runner. When unset,
# http://localhost:${DOCUMENT_ARENA_WEB_PORT} and http://127.0.0.1:${DOCUMENT_ARENA_WEB_PORT}
# are allowed. Use a comma-separated list when the web app has a custom origin.
# DOCUMENT_ARENA_RUNNER_ALLOWED_ORIGINS=http://document-arena.test:3000,https://document-arena.test

# Azure Document Intelligence (remote OCR parser). Set in a local .env; the
# runner injects these into the azure-di container. Never commit real values.
AZURE_DI_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_DI_KEY=<your-key>
