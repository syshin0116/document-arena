{
  "apiVersion": "document-arena.dev/component/v1alpha1",
  "kind": "Component",
  "metadata": {
    "id": "opendataloader-pdf",
    "version": "0.1.0",
    "displayName": "OpenDataLoader PDF",
    "upstreamVersion": "2.5.0"
  },
  "spec": {
    "role": "parser",
    "accepts": [
      "document-arena/source-document@v1alpha1"
    ],
    "produces": "document-arena/parsed-document@v1alpha1",
    "executor": {
      "protocol": "oci-batch/v1",
      "image": "document-arena/opendataloader-pdf:2.5.0"
    },
    "optionsSchema": "./options.schema.json",
    "capabilities": {
      "digitalPdf": true,
      "ocr": false,
      "geometry": "native",
      "tables": true,
      "readingOrder": true,
      "progress": {
        "mode": "phase",
        "partialResults": "none"
      }
    },
    "requirements": {
      "gpu": false,
      "network": "none",
      "memoryMiB": 2048,
      "cpus": 2
    }
  }
}
