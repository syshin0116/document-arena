{
  "apiVersion": "document-arena.dev/component/v1alpha1",
  "kind": "Component",
  "metadata": {
    "id": "azure-di",
    "version": "0.1.0",
    "displayName": "Azure Document Intelligence",
    "upstreamVersion": "azure-ai-documentintelligence@1.0.2"
  },
  "spec": {
    "role": "parser",
    "accepts": [
      "document-arena/source-document@v1alpha1"
    ],
    "produces": "document-arena/parsed-document@v1alpha1",
    "executor": {
      "protocol": "oci-batch/v1",
      "image": "document-arena/azure-di:0.1.0"
    },
    "optionsSchema": "./options.schema.json",
    "capabilities": {
      "digitalPdf": true,
      "ocr": true,
      "geometry": "native",
      "tables": true,
      "readingOrder": true,
      "progress": {
        "mode": "phase",
        "partialResults": "none"
      }
    },
    "requirements": {
      "gpu": false,
      "network": "remote",
      "memoryMiB": 2048,
      "cpus": 2,
      "connection": {
        "type": "azure-di",
        "title": "Azure Document Intelligence",
        "description": "Uses your Azure Document Intelligence resource for this local runner session.",
        "fields": [
          {
            "name": "endpoint",
            "label": "Endpoint",
            "description": "The HTTPS endpoint for your Azure Document Intelligence resource.",
            "secret": false,
            "format": "uri",
            "placeholder": "https://<resource>.cognitiveservices.azure.com/",
            "minLength": 39,
            "maxLength": 2048,
            "allowedHostSuffixes": [
              ".cognitiveservices.azure.com"
            ]
          },
          {
            "name": "key",
            "label": "API key",
            "description": "An Azure resource key. It stays only in runner memory for this session.",
            "secret": true,
            "format": "text",
            "placeholder": "Enter an Azure resource key",
            "minLength": 16,
            "maxLength": 4096
          }
        ],
        "env": {
          "endpoint": "AZURE_DI_ENDPOINT",
          "key": "AZURE_DI_KEY"
        }
      }
    }
  }
}
