{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parser-arena.dev/schemas/job-event.v1alpha1.json",
  "type": "object",
  "required": [
    "apiVersion",
    "type"
  ],
  "properties": {
    "apiVersion": {
      "const": "parser-arena.dev/job-event/v1alpha1"
    },
    "type": {
      "enum": [
        "stage.phase",
        "stage.completed",
        "stage.failed"
      ]
    },
    "jobId": {
      "type": "string"
    },
    "stageRunId": {
      "type": "string"
    },
    "phase": {
      "enum": [
        "inspecting",
        "parsing",
        "normalizing"
      ]
    }
  }
}
